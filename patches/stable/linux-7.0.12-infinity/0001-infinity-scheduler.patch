@@ -781,6 +781,11 @@ dma_fence_default_wait_cb(struct dma_fence *fence, struct dma_fence_cb *cb)
 	struct default_wait_cb *wait =
 		container_of(cb, struct default_wait_cb, base);
 
+	if (wait->task) {
+		wait->task->infinity.subsystem_tags |= INFTY_TAG_GRAPHICS;
+		wait->task->infinity.tag_timestamp = ktime_get_ns();
+	}
+
 	wake_up_state(wait->task, TASK_NORMAL);
 }
 
