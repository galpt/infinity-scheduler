From 33b19df701c7b5894ef9f99947ddc807f06b8448 Mon Sep 17 00:00:00 2001
From: Galih Tama <galpt@v.recipes>
Date: Wed, 1 Jul 2026 22:15:35 +0700
Subject: [PATCH 2/2] sched/infinity: add EMA vruntime scaling for CPU
 allocation

Current Infinity v3 EMA modulation only affects scheduling order (slice
size and wakeup vslice), but EEVDF's vruntime accounting ensures tasks
with equal nice values still receive equal CPU time over the long run.
This makes the EMA effective only for scheduling latency, not allocation.

Add infinity_vruntime_scale() to modify the vruntime advancement rate
based on the EMA signal. CPU-bound tasks (high EMA) advance vruntime
faster, reducing their effective CPU allocation. Interactive tasks (low
EMA) advance at the normal rate, preserving their fair share.

The scaling factor mirrors infinity_slice() exactly:
  slice = share * (100 - pct * 3/4) / 100
  vruntime_scale = 100 / (100 - pct * 3/4)
At EMA=100%: slice=25%, vruntime=4x, effective CPU=1/4
At EMA=0%:   slice=100%, vruntime=1x, effective CPU=full

Signed-off-by: Galih Tama <galpt@v.recipes>
---
 kernel/sched/fair.c           |  6 +++++-
 kernel/sched/infinity_sched.c | 16 ++++++++++++++++
 kernel/sched/infinity_sched.h | 14 ++++++++++++++
 3 files changed, 35 insertions(+), 1 deletion(-)

diff --git a/kernel/sched/fair.c b/kernel/sched/fair.c
index 81447cbc9..413c09fd1 100644
--- a/kernel/sched/fair.c
+++ b/kernel/sched/fair.c
@@ -1262,7 +1262,11 @@ static void update_curr(struct cfs_rq *cfs_rq)
 	if (entity_is_task(curr)) { struct task_struct *p__ = task_of(curr);
 		infinity_consume(&p__->infinity, delta_exec); }
 
-	curr->vruntime += calc_delta_fair(delta_exec, curr);
+	curr->vruntime += infinity_vruntime_scale(
+		calc_delta_fair(delta_exec, curr),
+		entity_is_task(curr)
+			? task_of(curr)->infinity.ema
+			: 0);
 	resched = update_deadline(cfs_rq, curr);
 	update_min_vruntime(cfs_rq);
 
diff --git a/kernel/sched/infinity_sched.c b/kernel/sched/infinity_sched.c
index 4b671e084..4857bb0b3 100644
--- a/kernel/sched/infinity_sched.c
+++ b/kernel/sched/infinity_sched.c
@@ -284,6 +284,22 @@ u64 infinity_wakeup_scale(u64 vslice, struct infinity_ctx *ctx)
 	return vslice * (100ULL - boost) / 100ULL;
 }
 
+/* ------------------------------------------------------------------ */
+/* infinity_vruntime_scale — EMA vruntime advancement scaling          */
+/* ------------------------------------------------------------------ */
+
+u64 infinity_vruntime_scale(u64 vdelta, u64 ema)
+{
+	if (ema) {
+		u64 pct = ema * 100ULL / INFINITY_BUDGET_MAX_NS;
+		u64 denom = 100ULL - pct * 3ULL / 4ULL;
+
+		if (denom < 100ULL)
+			vdelta = div64_u64(vdelta * 100ULL, denom);
+	}
+	return vdelta;
+}
+
 /* ------------------------------------------------------------------ */
 /* infinity_rt_consume — EMA climb on RT wakeup                        */
 /* ------------------------------------------------------------------ */
diff --git a/kernel/sched/infinity_sched.h b/kernel/sched/infinity_sched.h
index fa7843156..8186bbdc7 100644
--- a/kernel/sched/infinity_sched.h
+++ b/kernel/sched/infinity_sched.h
@@ -10,6 +10,7 @@
  *   ────────────────────────────────   ─────────────────────────────────────
  *   update_deadline()       ──call──► infinity_slice()        — fair-share slice
  *   update_curr()           ──call──► infinity_consume()      — EMA budget consumption
+ *   update_curr()           ──call──► infinity_vruntime_scale() — EMA vruntime scaling
  *   enqueue_task_fair()     ──call──► infinity_wakeup()       — EMA decay on wakeup
  *   dequeue_task_fair()     ──call──► (records last_sleep_ns) — sleep tracking
  *   pick_eevdf()            ──check──► futex_waiting          — bypass protect_slice (v3)
@@ -122,6 +123,19 @@ void infinity_fork_init(struct infinity_ctx *ctx, u64 now);
  */
 u64 infinity_wakeup_scale(u64 vslice, struct infinity_ctx *ctx);
 
+/*
+ * infinity_vruntime_scale — scale vruntime advancement by EMA
+ *
+ * Called from update_curr() to advance vruntime faster for CPU-bound
+ * tasks (high EMA).  The scaling factor mirrors infinity_slice(): a
+ * task that receives a 25% slice at EMA=100% has its vruntime advanced
+ * 4x faster, reducing its effective CPU allocation by the same ratio.
+ *
+ *   EMA ~= 0             (interactive):   ~1x (normal)
+ *   EMA ~= BUDGET_MAX    (CPU-bound):     ~4x
+ */
+u64 infinity_vruntime_scale(u64 vdelta, u64 ema);
+
 void infinity_rt_consume(struct infinity_ctx *ctx, u64 delta_ns);
 void infinity_rt_wakeup(struct infinity_ctx *ctx);
 u8   infinity_rt_effective_prio(u8 base_prio, struct infinity_ctx *ctx);
-- 
